{
  "name": "@termlnk-server/database",
  "type": "module",
  "version": "0.2.3",
  "private": true,
  "description": "Database plugin + IDBAdaptorService abstraction (Postgres via node-pg).",
  "license": "PolyForm-Noncommercial-1.0.0",
  "exports": {
    ".": "./src/index.ts",
    "./node-pg": "./src/adaptors/node-pg.adaptor.ts",
    "./entities": "./src/entities/index.ts",
    "./entities/base": "./src/entities/base.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts"
  },
  "peerDependencies": {
    "pg": ">=8.16.3",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "dependencies": {
    "@termlnk-server/core": "workspace:*",
    "drizzle-orm": "^1.0.0-rc.3"
  },
  "devDependencies": {
    "@termlnk-server/shared": "workspace:*",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.3",
    "pg": "^8.21.0",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3"
  }
}
