# termlnk-server deployment configuration.
# Copy to .env and edit; install.sh writes a populated copy automatically.

# === Image ===
# Pin to a specific release in production (e.g. v0.1.0). Defaults to `latest`.
TERMLNK_VERSION=latest

# === HTTPS (Caddy reverse proxy) ===
# Leave both blank for an HTTP-only deployment exposing port 4000 directly.
# Set both, then bring the stack up with the HTTPS overlay, to enable
# auto Let's Encrypt certificate provisioning:
#   docker compose -f docker-compose.yml -f docker-compose.https.yml up -d
# install.sh / deploy.sh add the overlay automatically when DOMAIN is set.
DOMAIN=
ACME_EMAIL=

# === Network bind ===
# Where to bind exposed container ports on the host.
#   - HTTP-only deploy:          SERVER_BIND=0.0.0.0
#   - HTTPS deploy (via Caddy):  SERVER_BIND=127.0.0.1  (Caddy takes 80/443)
SERVER_BIND=0.0.0.0
SERVER_PORT=4000
# Postgres + Redis default to loopback — never expose these publicly.
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND=127.0.0.1
REDIS_PORT=6379

# === Database ===
POSTGRES_USER=termlnk
POSTGRES_PASSWORD=termlnk
POSTGRES_DB=termlnk_server

# === Auth ===
# install.sh generates these with `openssl rand -base64 64`. Never reuse across deployments.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# === Policy ===
ALLOW_OPEN_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false
# Comma-separated origin allowlist. Use `*` only for testing.
CORS_ORIGINS=*

# === Google OAuth (optional) ===
# Off by default. To enable: create an OAuth 2.0 Client (type "Web application")
# in Google Cloud Console, fill all three values below, then flip ENABLED to true.
# GOOGLE_REDIRECT_URI must EXACTLY match an "Authorized redirect URI" on that
# client and point at this server's public callback:
#   HTTPS deploy:  https://<your-domain>/auth/google/callback
#   HTTP  deploy:  http://<host>:4000/auth/google/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Desktop deep-link the browser flow returns the one-time relay code to.
# Override only if the desktop app registers a different scheme.
GOOGLE_DESKTOP_CALLBACK_URL=termlnk://auth/callback
