## termlnk-server runtime config
## Copy to .env (or apps/server/.env) and fill in values.

## --- Database ---
DATABASE_URL=postgres://termlnk:termlnk@localhost:5432/termlnk_server

## --- Redis (poke pubsub) ---
REDIS_URL=redis://localhost:6379

## --- HTTP listen ---
PORT=4000
HOST=0.0.0.0

## --- JWT signing ---
## Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=changeme-access-secret-replace-with-64-bytes-base64
JWT_REFRESH_SECRET=changeme-refresh-secret-replace-with-64-bytes-base64
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

## --- Registration ---
ALLOW_OPEN_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

## --- CORS (comma separated; * to allow all) ---
CORS_ORIGINS=*

## --- Google OAuth (optional, off by default) ---
## Identity-only Google sign-in. When GOOGLE_OAUTH_ENABLED=true the three values
## below are required; an empty value counts as unset. GOOGLE_REDIRECT_URI must
## match an Authorized redirect URI on your Google OAuth client, e.g.
## http://localhost:4000/auth/google/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DESKTOP_CALLBACK_URL=termlnk://auth/callback
